APP_NAME="NewsHub Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# Filament Admin Panel (set for production: admin.indfeeds.com)
FILAMENT_ADMIN_DOMAIN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=newshub_pro
DB_USERNAME=root
DB_PASSWORD=
DB_PERSISTENT=false

# Read replica (optional)
DB_READ_HOST=
DB_READ_PORT=
DB_READ_USERNAME=
DB_READ_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
MEDIA_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@newshub.pro"
MAIL_FROM_NAME="${APP_NAME}"

FIREBASE_CREDENTIALS="${STORAGE_PATH}/app/firebase-credentials.json"
FIREBASE_PROJECT=app

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SANCTUM_EXPIRATION=60
SANCTUM_ACCESS_TOKEN_TTL=60
SANCTUM_REFRESH_TOKEN_TTL=30

# CORS (required in production)
CORS_ALLOWED_ORIGINS=
CORS_SUPPORTS_CREDENTIALS=false

# Trusted reverse proxies (comma-separated IPs or *)
TRUSTED_PROXIES=*

# Monitoring dashboards (disabled by default in production)
HORIZON_ENABLED=false
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
MONITORING_ALLOWED_EMAILS=admin@newshub.pro

# Device registration abuse protection
DEVICE_REGISTER_PER_MINUTE=5
DEVICE_REGISTER_PER_DAY=20

# Subscription & revenue validation
SUBSCRIPTION_STRICT_RECEIPT_VALIDATION=true
APPLE_SHARED_SECRET=
GOOGLE_PLAY_SERVICE_ACCOUNT=
REVENUE_EVENTS_MAX_PER_MINUTE=60
REVENUE_EVENTS_MAX_AMOUNT=1.0

# Database backup
MYSQLDUMP_BINARY=mysqldump

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_BACKUP_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# CDN
CDN_ENABLED=false
CDN_URL=
CDN_SIGNED_URL_TTL=3600

# Horizon
HORIZON_PREFIX=newshub_horizon
HORIZON_MAX_PROCESSES=30

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_ENVIRONMENT=

# Alerting
ALERTING_ENABLED=false
ALERT_SLACK_WEBHOOK=
ALERT_EMAIL=
ALERT_CPU_THRESHOLD=85
ALERT_MEMORY_THRESHOLD=85
ALERT_QUEUE_BACKLOG=1000
ALERT_DB_CONNECTIONS=80
ALERT_NOTIFICATION_FAILURE_RATE=0.1

# Backup
BACKUP_ENABLED=true
BACKUP_DISK=s3-backup
BACKUP_RETENTION_DAYS=30

# Rate Limiting
API_RATE_LIMIT=120
AUTH_RATE_LIMIT=10
PUBLIC_RATE_LIMIT=300

# Health Checks
HEALTH_CHECK_DATABASE=true
HEALTH_CHECK_REDIS=true
HEALTH_CHECK_QUEUE=true
HEALTH_CHECK_STORAGE=true

VITE_APP_NAME="${APP_NAME}"
